@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Mikkelhm.Models.EllabmHome>
@{
    Layout = null;
    var galleryPage = Model.Children?.FirstOrDefault(x => x.ContentType.Alias == "ellabmGallery");
}
<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
    <title>@Model.Headline</title>
    <link rel="stylesheet" href="/ellabm/assets/css/main.css" />
</head>
<body>
    <!-- Password Gate -->
    <div id="password-gate">
        <div class="gate-content">
            <h1>🎉</h1>
            <h2>Ellas Fest!</h2>
            <p>Indtast koden for at uploade billeder</p>
            <input type="text" id="password-input" inputmode="numeric" pattern="[0-9]*" placeholder="Kode..." maxlength="4" autocomplete="off" />
            <button id="password-submit">Kom ind!</button>
            <p id="password-error" class="error hidden">Forkert kode, prøv igen!</p>
        </div>
    </div>

    <!-- Upload Section -->
    <div id="upload-section" class="hidden">
        <header>
            <h1>@Model.Headline</h1>
            @if (Model.Body != null)
            {
                <div class="body-text">@Model.Body</div>
            }
        </header>

        <div id="upload-area">
            <div id="drop-zone">
                <p>📸 Tryk her eller træk billeder hertil</p>
                <input type="file" id="file-input" accept="image/*" capture="environment" multiple />
            </div>
            <div id="uploader-name-section">
                <input type="text" id="uploader-name" placeholder="Dit navn (valgfrit)" />
            </div>
        </div>

        <div id="preview-area" class="hidden"></div>
        <div id="progress-area" class="hidden">
            <div id="progress-bar"><div id="progress-fill"></div></div>
            <p id="progress-text"></p>
        </div>
        <div id="upload-status" class="hidden"></div>

        @if (galleryPage != null)
        {
            <a href="@galleryPage.Url()" class="gallery-link">📺 Se billedegalleriet</a>
        }

        <footer>
            <p>Ellas Fest 2026</p>
        </footer>
    </div>

    <script src="/ellabm/assets/js/upload.js"></script>
</body>
</html>
